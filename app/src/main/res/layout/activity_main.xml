<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000">
    <com.alol.overlay.ui.GlassBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEGION OS v1.0"
            android:textSize="28sp"
            android:textColor="#00FFD1"
            android:textStyle="bold"
            android:shadowColor="#00FFD1"
            android:shadowRadius="15"
            android:layout_marginBottom="24dp"/>
        <Button
            android:id="@+id/activateBtn"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="INITIALIZE"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/glass_button_bg"
            android:layout_marginBottom="16dp"/>
        <Button
            android:id="@+id/stealthBtn"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="STEALTH MODE"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/glass_button_bg" />
    </LinearLayout>
</FrameLayout>
