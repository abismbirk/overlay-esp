<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:paddingTop="60dp">

        <!-- الشعار -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐 المترجم الفوري"
            android:textSize="28sp"
            android:textColor="#00FFD1"
            android:textStyle="bold"
            android:shadowColor="#00FFD1"
            android:shadowRadius="20"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ترجمة الصوت من الفيديو مباشرة"
            android:textSize="14sp"
            android:textColor="#80FFFFFF"
            android:layout_marginBottom="36dp" />

        <!-- اختيار اللغات -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tv_source_lang"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="English 🇺🇸"
                android:textSize="16sp"
                android:textColor="#FFF"
                android:gravity="center"
                android:padding="12dp"
                android:background="@drawable/glass_button_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" → "
                android:textSize="20sp"
                android:textColor="#00FFD1"
                android:layout_marginHorizontal="12dp" />

            <TextView
                android:id="@+id/tv_target_lang"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="العربية 🇸🇦"
                android:textSize="16sp"
                android:textColor="#FFF"
                android:gravity="center"
                android:padding="12dp"
                android:background="@drawable/glass_button_bg" />
        </LinearLayout>

        <!-- زر الترجمة الفورية -->
        <Button
            android:id="@+id/btn_live_translate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🎙️ بدء الترجمة الفورية"
            android:textColor="#000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="#FF00FFD1"
            android:layout_marginBottom="16dp" />

        <!-- باقي الميزات -->
        <Button android:id="@+id/btn_file_translate" style="@style/GlassButton" android:text="📁 ترجمة ملف صوتي" />
        <Button android:id="@+id/btn_history" style="@style/GlassButton" android:text="📜 سجل الترجمات" />
        <Button android:id="@+id/btn_saved" style="@style/GlassButton" android:text="⭐ الكلمات المحفوظة" />
        <Button android:id="@+id/btn_settings" style="@style/GlassButton" android:text="⚙️ الإعدادات" />

        <!-- شريط الحالة -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟢 جاهز"
            android:textColor="#80FFFFFF"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>
