<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.alol.overlay"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="29"
        android:targetSdkVersion="33" />

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <package android:name="com.itsaky.androidide" />
    </queries>

    <uses-permission android:name="com.itsaky.androidide.permission.BIND_LOG_SERVICE" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@android:drawable/ic_menu_view"
        android:label="Shadow Translator" >
        <activity
            android:name="com.alol.overlay.MainActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.alol.overlay.FloatingTranslationService"
            android:exported="false" />
        <service
            android:name="com.alol.overlay.AudioCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <provider
            android:name="com.itsaky.androidide.logsender.utils.LogSenderInstaller"
            android:authorities="com.alol.overlay.logsender-installer"
            android:enabled="@bool/logsender_enabled"
            android:exported="false" />

        <service
            android:name="com.itsaky.androidide.logsender.LogSenderService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>