<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0A0A1A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧬 THREAT INTEL CENTER"
        android:textSize="22sp"
        android:textColor="#00FFD1"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">
        <Button
            android:id="@+id/btn_tab_manual"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📂 Manual Extract"
            android:textColor="#FFF"
            android:background="#22FFFFFF" />
        <Button
            android:id="@+id/btn_tab_live"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🧪 Lab Upload"
            android:textColor="#FFF"
            android:background="#2200FFD1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_manual"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <EditText
            android:id="@+id/et_path"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="/sdcard/libbb/libanogs.so"
            android:textColor="#FFFFFF"
            android:background="#15FFFFFF"
            android:padding="12dp"
            android:hint="Path to libanogs.so"
            android:textColorHint="#80FFFFFF"/>

        <Button
            android:id="@+id/btn_extract"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⚡ EXTRACT OFFSETS"
            android:textColor="#000"
            android:background="#FF00FFD1"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_live"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟢 Upload your libanogs.so"
            android:textColor="#80FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_upload"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📤 CHOOSE FILE"
            android:textColor="#FFF"
            android:background="@drawable/glass_button_bg"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

    <ListView
        android:id="@+id/lv_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="#08FFFFFF"
        android:layout_marginTop="12dp"/>

    <Button
        android:id="@+id/btn_copy"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="📋 COPY ALL"
        android:textColor="#FFF"
        android:background="#2200FFD1"/>
</LinearLayout>
